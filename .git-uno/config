[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	ignorecase = true
	worktree = C:/wamp64/www
[remote "origin"]
	url = https://github.com/lirousme/uno.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	vscode-merge-base = origin/main
	merge = refs/heads/main
